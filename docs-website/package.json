{
  "name": "xote-website",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "generate-api-docs": "node scripts/generate-api-docs.cjs",
    "res:build": "npm run generate-api-docs && rescript",
    "res:clean": "rescript clean",
    "res:dev": "rescript -w",
    "dev": "node server.mjs",
    "dev:client": "vite",
    "build": "npm run res:build && npm run build:client && npm run build:server && npm run build:prerender",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/EntryServer.res.mjs --outDir build/server",
    "build:prerender": "node scripts/prerender.mjs",
    "preview": "NODE_ENV=production node server.mjs"
  },
  "dependencies": {
    "@rescript/core": "^1.6.1",
    "basefn": "^1.9.1",
    "highlight.js": "^11.11.1",
    "rescript-signals": "^1.3.0",
    "xote": "^4.16.0"
  },
  "devDependencies": {
    "rescript": "^12.0.0",
    "vite": "^7.1.12"
  }
}
