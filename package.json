{
  "name": "xote",
  "version": "0.0.0",
  "repository": {
    "url": "https://github.com/brnrdog/xote"
  },
  "main": "./dist/xote.cjs",
  "module": "./dist/xote.mjs",
  "exports": {
    ".": {
      "import": "./dist/xote.mjs",
      "require": "./dist/xote.cjs",
      "default": "./dist/xote.mjs"
    },
    "./node": "./src/Node.res.mjs",
    "./html": "./src/Html.res.mjs",
    "./jsx": "./src/XoteJSX.res.mjs",
    "./reactive-prop": "./src/ReactiveProp.res.mjs",
    "./route": "./src/Route.res.mjs",
    "./router": "./src/Router.res.mjs",
    "./ssr": "./src/SSR.res.mjs",
    "./ssr-context": "./src/SSRContext.res.mjs",
    "./ssr-state": "./src/SSRState.res.mjs",
    "./hydration": "./src/Hydration.res.mjs",
    "./signal": "./src/Signal.res.mjs",
    "./computed": "./src/Computed.res.mjs",
    "./effect": "./src/Effect.res.mjs",
    "./src/*": "./src/*",
    "./package.json": "./package.json",
    "./rescript.json": "./rescript.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src/**/*.res",
    "src/**/*.resi",
    "src/**/*.res.mjs",
    "rescript.json"
  ],
  "scripts": {
    "res:build": "rescript",
    "res:clean": "rescript clean",
    "res:dev": "rescript -w",
    "format": "rescript format",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docs:start": "cd docs-website && npm run dev",
    "docs:build": "cd docs-website && npm run build",
    "docs:serve": "cd docs-website && npm run preview",
    "test": "npx rescript && node tests/Tests.res.mjs"
  },
  "keywords": [
    "rescript",
    "signals",
    "xote",
    "reactivity"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "docs/CHANGELOG.md"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "docs/CHANGELOG.md"
          ]
        }
      ],
      "@semantic-release/github",
      "@semantic-release/npm"
    ]
  },
  "author": "Bernardo Gurgel <brnrdog@hey.com>",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.1.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "glob": "^11.1.0",
    "rescript": "^12.0.0",
    "semantic-release": "^25.0.1",
    "vite": "^7.3.2",
    "zekr": "^1.7.0"
  },
  "dependencies": {
    "rescript-signals": "^3.1.0"
  }
}
