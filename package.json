{
  "name": "xote",
  "version": "0.0.0",
  "repository": {
    "url": "https://github.com/brnrdog/xote"
  },
  "main": "./dist/xote.cjs",
  "module": "./dist/xote.mjs",
  "sideEffects": false,
  "files": [
    "dist",
    "src/**/*.res",
    "src/**/*.resi",
    "src/**/*.res.mjs",
    "rescript.json"
  ],
  "scripts": {
    "res:build": "rescript",
    "res:clean": "rescript clean",
    "res:dev": "rescript -w",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docs:start": "cd docs-website && npm run dev",
    "docs:build": "cd docs-website && npm run build",
    "docs:serve": "cd docs-website && npm run preview",
    "test": "npx rescript && node tests/Tests.res.mjs",
    "precoverage": "npx rescript && node scripts/generate-sourcemaps.mjs src",
    "coverage": "c8 node tests/Tests.res.mjs"
  },
  "keywords": [
    "rescript",
    "signals",
    "xote",
    "reactivity"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "docs/CHANGELOG.md"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "docs/CHANGELOG.md"
          ]
        }
      ],
      "@semantic-release/github",
      "@semantic-release/npm"
    ]
  },
  "author": "Bernardo Gurgel <brnrdog@hey.com>",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.1.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "glob": "^11.1.0",
    "rescript": "^12.0.0",
    "semantic-release": "^25.0.1",
    "vite": "^7.1.12",
    "c8": "^11.0.0",
    "source-map": "^0.7.6",
    "zekr": "^1.8.0"
  },
  "c8": {
    "include": [
      "src/**/*.res.mjs"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "report-dir": "coverage",
    "all": true
  },
  "dependencies": {
    "rescript-signals": "^1.3.3"
  }
}
